{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/widget/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/widget(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/[lang]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[lang]/auth/signin",
      "regex": "^/([^/]+?)/auth/signin(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/auth/signin(?:/)?$"
    },
    {
      "page": "/[lang]/auth/verify-request",
      "regex": "^/([^/]+?)/auth/verify\\-request(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/auth/verify\\-request(?:/)?$"
    },
    {
      "page": "/[lang]/dashboard",
      "regex": "^/([^/]+?)/dashboard(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/dashboard(?:/)?$"
    },
    {
      "page": "/[lang]/demo",
      "regex": "^/([^/]+?)/demo(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/demo(?:/)?$"
    },
    {
      "page": "/[lang]/get-started",
      "regex": "^/([^/]+?)/get\\-started(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/get\\-started(?:/)?$"
    },
    {
      "page": "/[lang]/pricing",
      "regex": "^/([^/]+?)/pricing(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/pricing(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/auth/signin",
      "regex": "^/auth/signin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/signin(?:/)?$"
    },
    {
      "page": "/auth/verify-request",
      "regex": "^/auth/verify\\-request(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/verify\\-request(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}